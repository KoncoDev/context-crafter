# ── Deployment target ─────────────────────────────────────────────
# 'vercel' (default) or 'cloudflare'
# Must be set as a BUILD-TIME env var on Vercel — not just runtime.
DEPLOY_TARGET=vercel

# ── PocketBase ─────────────────────────────────────────────────────
# Your PocketBase instance URL (e.g. https://myapp.pockethost.io)
# PUBLIC_ prefix exposes this to the browser bundle — set at BUILD time.
PUBLIC_POCKETBASE_URL=https://your-pb-instance.com

# Enable PocketBase integration — set to 'true' for production.
# ⚠️ This is a STATIC env var baked in at build time on Vercel.
#    Set it under Project Settings → Environment Variables → all environments.
ENABLE_POCKETBASE=true

# ── N8N Webhook URLs ───────────────────────────────────────────────
# Server-side only — never exposed to the client.
# These are DYNAMIC (read at runtime), so they can be changed without redeploy.
N8N_WEBHOOK_STEP1=https://your-n8n.com/webhook/fact-extractor
N8N_WEBHOOK_STEP2=https://your-n8n.com/webhook/persona-generator
N8N_WEBHOOK_STEP3=https://your-n8n.com/webhook/researcher
N8N_WEBHOOK_STEP4=https://your-n8n.com/webhook/architect
N8N_WEBHOOK_STEP5=https://your-n8n.com/webhook/designer

# ── Vercel deployment checklist ───────────────────────────────────
# In Vercel Project Settings → Environment Variables, add:
#
#   DEPLOY_TARGET          = vercel          (plain text, all envs)
#   PUBLIC_POCKETBASE_URL  = https://...     (plain text, all envs)
#   ENABLE_POCKETBASE      = true            (plain text, all envs)
#   N8N_WEBHOOK_STEP1      = https://...     (sensitive, all envs)
#   N8N_WEBHOOK_STEP2      = https://...     (sensitive, all envs)
#   N8N_WEBHOOK_STEP3      = https://...     (sensitive, all envs)
#   N8N_WEBHOOK_STEP4      = https://...     (sensitive, all envs)
#   N8N_WEBHOOK_STEP5      = https://...     (sensitive, all envs)
#
# Build command:  npm run build
# Output dir:     .svelte-kit/output  (auto-detected by Vercel)
# Framework:      SvelteKit           (auto-detected)

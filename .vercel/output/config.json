{
	"version": 3,
	"routes": [
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^/?(?:/__data.json)?$",
			"dest": "/(public)"
		},
		{
			"src": "^/api/sitemap\\.xml/?(?:/__data.json)?$",
			"dest": "/api/sitemap.xml"
		},
		{
			"src": "^/app/?(?:/__data.json)?$",
			"dest": "/app"
		},
		{
			"src": "^/app/projects/new/?(?:/__data.json)?$",
			"dest": "/app/projects/new"
		},
		{
			"src": "^/app/projects/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/app/projects/[id]"
		},
		{
			"src": "^/app/projects/([^/]+?)/generate-personas/?(?:/__data.json)?$",
			"dest": "/app/projects/[id]/generate-personas"
		},
		{
			"src": "^/app/projects/([^/]+?)/master/?(?:/__data.json)?$",
			"dest": "/app/projects/[id]/master"
		},
		{
			"src": "^/app/projects/([^/]+?)/research/?(?:/__data.json)?$",
			"dest": "/app/projects/[id]/research"
		},
		{
			"src": "^/app/projects/([^/]+?)/variants/([^/]+?)/?(?:/__data.json)?$",
			"dest": "/app/projects/[id]/variants/[variantId]"
		},
		{
			"src": "^/login/?(?:/__data.json)?$",
			"dest": "/login"
		},
		{
			"src": "^/logout/?(?:/__data.json)?$",
			"dest": "/logout"
		},
		{
			"src": "/.*",
			"dest": "/![-]/catchall"
		}
	],
	"overrides": {}
}